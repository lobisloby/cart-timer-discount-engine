';
    document.head.appendChild(el);
  }

  /* ==========================================================
     BUILD TIMER HTML
     ========================================================== */
    function buildHTML(cfg) {
    var barColor = cfg.style === 'gradient' ? '#fff' : cfg.color;
    return '<div class="ct-wrap"><div id="ct-timer" class="ct ct-' + cfg.style + '" style="--a:' + cfg.color + ';">' +
      '<div class="ct-hdr"><span class="ct-fire">🔥</span><span class="ct-hl">' + cfg.headline + '</span></div>' +
      '<div class="ct-cd">' +
        '<div class="ct-u"><span class="ct-n" id="ct-h">00</span><span class="ct-lb">Hours</span></div>' +
        '<span class="ct-sp">:</span>' +
        '<div class="ct-u"><span class="ct-n" id="ct-m">' + pad(cfg.minutes) + '</span><span class="ct-lb">Mins</span></div>' +
        '<span class="ct-sp">:</span>' +
        '<div class="ct-u"><span class="ct-n" id="ct-s">00</span><span class="ct-lb">Secs</span></div>' +
      '</div>' +
      '<div class="ct-pg"><div class="ct-tk"><div class="ct-fl" id="ct-f" style="height:4px;background:' + barColor + ';"></div></div></div>' +
      '<div class="ct-ft">' +
        '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' +
        '<span>' + cfg.footer + '</span>' +
      '</div>' +
    '</div>' +
    '<div id="ct-expired-wrap" class="ct-expired-wrap"></div>' +
    '</div>';
  }

  /* ==========================================================
     TIMER ENGINE — two intervals: digits 1s, bar 50ms
     ========================================================== */
  var digitTimer = null, barTimer = null, endTime = 0, totalMs = 0, VID = '';

  function updateDigits() {
    var h = document.getElementById('ct-h'), m = document.getElementById('ct-m'),
        s = document.getElementById('ct-s'), t = document.getElementById('ct-timer');
    if (!h) return;

    var left = endTime - Date.now();
    if (left <= 0) {
      clearInterval(digitTimer);
      clearInterval(barTimer);
      h.textContent = '00'; m.textContent = '00'; s.textContent = '00';
      var f = document.getElementById('ct-f');
      if (f) f.setAttribute('style', 'width:0%;height:4px;background:transparent;border-radius:2px;'); 
      if (t) t.classList.remove('urgent');
      onExpire();
      return;
    }

    var sec = Math.floor(left / 1000);
    h.textContent = pad(Math.floor(sec / 3600));
    m.textContent = pad(Math.floor((sec % 3600) / 60));
    s.textContent = pad(sec % 60);
    if (sec <= 30) t.classList.add('urgent'); else t.classList.remove('urgent');
  }

  function updateBar() {
    var f = document.getElementById('ct-f');
    if (!f) return;
    var left = endTime - Date.now();
    var pct = left <= 0 ? 0 : Math.max(0, (left / totalMs) * 100);
    var t = document.getElementById('ct-timer');
    var bg = '#6366f1';
    if (t) {
      bg = t.style.getPropertyValue('--a') || '#6366f1';
      if (t.classList.contains('ct-gradient')) bg = '#ffffff';
    }
    f.setAttribute('style', 'width:' + pct + '%;height:4px;background:' + bg + ';border-radius:2px;display:block;');
  }

    function startCountdown(expiresAt, mins) {
    timerActive = true;
    endTime = new Date(expiresAt).getTime();

    var safeMins = parseInt(mins, 10);
    if (!safeMins || safeMins <= 0) safeMins = 10;
    totalMs = safeMins * 60 * 1000;

    console.log('[CartTimer] ⏱️ startCountdown — expiresAt:', expiresAt, 'mins:', safeMins, 'totalMs:', totalMs, 'left:', endTime - Date.now());

    updateDigits();
    updateBar();
    clearInterval(digitTimer);
    clearInterval(barTimer);
    digitTimer = setInterval(updateDigits, 1000);
    barTimer = setInterval(updateBar, 50);
  }

  /* ==========================================================
     EXPIRE HANDLER
     ========================================================== */
  function onExpire() {
    timerActive = false;
    discountApplied = false;
    localStorage.removeItem('ct_discount_applied');

    restorePrice();

    api('expire', VID).then(function(data) {
      console.log('[CartTimer] ⏰ Expired, cooldown set:', data);
      showExpired(data.cooldownUntil);
    }).catch(function() {
      showExpired(null);
    });
  }

  function showExpired(cooldownUntil) {
    var timerEl = document.getElementById('ct-timer');
    var wrapEl = document.getElementById('ct-expired-wrap');
    if (!wrapEl) return;

    if (timerEl) timerEl.style.display = 'none';

    var accent = '#6366f1';
    if (timerEl) {
      accent = timerEl.style.getPropertyValue('--a') || '#6366f1';
    }

    function hexRgb(hex) {
      hex = hex.replace('#', '');
      if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
      return {
        r: parseInt(hex.substring(0,2), 16),
        g: parseInt(hex.substring(2,4), 16),
        b: parseInt(hex.substring(4,6), 16)
      };
    }
    var c = hexRgb(accent);
    var bgSoft   = 'rgba('+c.r+','+c.g+','+c.b+', 0.05)';
    var bgMed    = 'rgba('+c.r+','+c.g+','+c.b+', 0.10)';
    var bgStrong = 'rgba('+c.r+','+c.g+','+c.b+', 0.15)';

    var smiley = '<svg width="30" height="30" viewBox="0 0 24 24" fill="none">' +
      '<circle cx="12" cy="12" r="10" fill="'+accent+'" opacity="0.12"/>' +
      '<circle cx="12" cy="12" r="10" stroke="'+accent+'" stroke-width="1.5" fill="none"/>' +
      '<circle cx="9" cy="10" r="1.3" fill="'+accent+'"/>' +
      '<circle cx="15" cy="10" r="1.3" fill="'+accent+'"/>' +
      '<path d="M8.5 14.5C9 16.5 10.5 17.5 12 17.5C13.5 17.5 15 16.5 15.5 14.5" stroke="'+accent+'" stroke-width="1.5" stroke-linecap="round" fill="none"/>' +
    '</svg>';

    var gift = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none">' +
      '<rect x="3" y="11" width="18" height="10" rx="2" fill="'+accent+'" opacity="0.1" stroke="'+accent+'" stroke-width="1.3"/>' +
      '<rect x="5" y="7" width="14" height="5" rx="1.5" fill="'+accent+'" opacity="0.15" stroke="'+accent+'" stroke-width="1.3"/>' +
      '<line x1="12" y1="7" x2="12" y2="21" stroke="'+accent+'" stroke-width="1.3"/>' +
      '<path d="M12 7C12 7 12 4 9.5 4C7 4 7 6 7 6C7 6 7 7 9 7" stroke="'+accent+'" stroke-width="1.3" stroke-linecap="round" fill="none"/>' +
      '<path d="M12 7C12 7 12 4 14.5 4C17 4 17 6 17 6C17 6 17 7 15 7" stroke="'+accent+'" stroke-width="1.3" stroke-linecap="round" fill="none"/>' +
    '</svg>';

    var canRestart = false;
    var timeHTML = '';

    if (cooldownUntil) {
      var cdEnd = new Date(cooldownUntil).getTime();
      var left = cdEnd - Date.now();
      if (left <= 0) {
        canRestart = true;
      } else {
        var hrs = Math.floor(left / 3600000);
        var mins = Math.floor((left % 3600000) / 60000);
        timeHTML = '<p class="ct-bn-time" style="color:'+accent+';">' +
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' +
          '<span id="ct-bn-countdown">' + (hrs > 0 ? hrs + 'h ' + mins + 'm' : mins + 'm') + ' remaining</span>' +
        '</p>';
      }
    }

    var btnHTML = canRestart
      ? '<button id="ct-bn-restart" class="ct-bn-btn" style="background:'+accent+';color:#fff;">🎉 Get your new discount</button>'
      : '<button id="ct-bn-restart" class="ct-bn-btn" disabled style="background:'+bgStrong+';color:'+accent+';">⏳ Next offer loading...</button>';

    wrapEl.innerHTML = '<div class="ct-bn" style="background:linear-gradient(135deg, '+bgSoft+' 0%, rgba(255,255,255,0.97) 40%, rgba(255,255,255,0.97) 60%, '+bgSoft+' 100%); border:1px solid '+bgMed+'; box-shadow:0 4px 20px rgba(0,0,0,0.04);">' +
      '<div class="ct-bn-dots"><div class="ct-bn-dot" style="background:'+accent+';"></div><div class="ct-bn-dot" style="background:'+accent+';"></div><div class="ct-bn-dot" style="background:'+accent+';"></div></div>' +
      '<div class="ct-bn-icon" style="background:'+bgMed+';">'+smiley+'</div>' +
      '<div class="ct-bn-body">' +
        '<p class="ct-bn-title" style="color:'+accent+';">Ready for your next offer?</p>' +
        '<p class="ct-bn-sub" style="color:'+accent+';">for a new discount!</p>' +
        timeHTML +
        btnHTML +
      '</div>' +
      '<div class="ct-bn-gift" style="background:'+bgMed+';">'+gift+'</div>' +
    '</div>';

    wrapEl.classList.add('show');

    var restartBtn = document.getElementById('ct-bn-restart');
    if (restartBtn) {
      restartBtn.addEventListener('click', function() {
        if (restartBtn.disabled) return;
        wrapEl.classList.remove('show');
        wrapEl.innerHTML = '';
        if (timerEl) timerEl.style.display = '';
        startNewTimer();
      });
    }

    if (cooldownUntil && !canRestart) {
      var cdInterval = setInterval(function() {
        var now = Date.now();
        var cdEndTime = new Date(cooldownUntil).getTime();
        var remaining = cdEndTime - now;

        if (remaining <= 0) {
          clearInterval(cdInterval);
          showExpired(cooldownUntil);
          return;
        }

        var countdownEl = document.getElementById('ct-bn-countdown');
        if (countdownEl) {
          var h = Math.floor(remaining / 3600000);
          var m = Math.floor((remaining % 3600000) / 60000);
          var s = Math.floor((remaining % 60000) / 1000);
          countdownEl.textContent = h > 0
            ? h + 'h ' + m + 'm remaining'
            : m + 'm ' + s + 's remaining';
        }
      }, 1000);
    }

    console.log('[CartTimer] 🎨 Friendly expired banner shown');
  }

  /* ==========================================================
     START NEW TIMER
     ========================================================== */
  function startNewTimer() {
    api('start', VID).then(function(data) {
      if (data.status === 'active') {
        startCountdown(data.expiresAt, data.timerMinutes);
        if (data.discountCode) {
          discountApplied = false;
          interceptAddToCart(data.discountCode);
          applyDiscount(data.discountCode);
        }
        getProduct().then(function(p) {
          if (p) modifyPrice(p, data.discountPct, document.getElementById('ct-timer')?.style.getPropertyValue('--a') || '#6366f1');
        });
      } else if (data.status === 'cooldown') {
        showExpired(data.cooldownUntil);
      }
    });
  }

  /* ==========================================================
     INJECT
     ========================================================== */
  function findTarget() {
    var sels = ['.product-form__buttons','.product-form__submit','.product__submit',
      '.shopify-payment-button','form[action*="/cart/add"] [type="submit"]',
      'button[name="add"]','[data-add-to-cart]','#AddToCart','.add-to-cart',
      'form[action*="/cart/add"]'];
    for (var i=0;i<sels.length;i++) { var el=document.querySelector(sels[i]); if(el) return el; }
    return null;
  }

  function inject(cfg) {
    if (document.getElementById('ct-timer')) return;
    var target = findTarget();
    if (!target) return;

    var form = target.closest('form[action*="/cart/add"]');
    var parent = form || target.parentElement;

    injectCSS(cfg.color);
    var wrap = document.createElement('div');
    wrap.innerHTML = buildHTML(cfg);
    var node = wrap.firstElementChild;

    var btnGroup = parent.querySelector('.product-form__buttons')
                || parent.querySelector('.shopify-payment-button')
                || parent.querySelector('[type="submit"]');

    if (btnGroup) {
      var btnWidth = btnGroup.offsetWidth;
      if (btnWidth > 100) {
        node.style.setProperty('--ct-width', btnWidth + 'px');
      }
    }

    if (btnGroup && btnGroup.parentElement === parent) {
      parent.insertBefore(node, btnGroup);
    } else {
      parent.insertBefore(node, parent.firstChild);
    }

    setTimeout(function() {
      var btn = parent.querySelector('.product-form__buttons')
             || parent.querySelector('.shopify-payment-button')
             || parent.querySelector('[type="submit"]');
      if (btn) {
        var w = btn.offsetWidth;
        if (w > 100 && node) {
          node.style.setProperty('--ct-width', w + 'px');
        }
      }
    }, 200);
  }

  /* ==========================================================
     MAIN INIT
     ========================================================== */
  function init() {
    if (!isProductPage()) return;

    VID = getVid();

    Promise.all([api('settings', null), getProduct()])
    .then(function(results) {
      var settings = results[0];
      var product = results[1];

      if (!settings || settings.enabled === false) return;

      var cfg = {
        style:    settings.timerStyle      || 'dark',
        minutes:  settings.timerMinutes    || 10,
        discount: settings.discountPercent || 15,
        headline: settings.urgencyText     || 'Hurry! This deal ends soon',
        color:    settings.primaryColor     || '#6366f1',
        footer:   settings.footerText       || 'Your discount is reserved for you',
        code:     settings.discountCode     || null
      };

      inject(cfg);

      api('start', VID).then(function(data) {
        if (data.status === 'active') {
          var pct = data.discountPct || cfg.discount;

          startCountdown(data.expiresAt, data.timerMinutes || cfg.minutes);

          if (product) modifyPrice(product, pct, cfg.color);

          var code = data.discountCode || cfg.code;
          if (code) {
            interceptAddToCart(code);
            applyDiscount(code);
          }

        } else if (data.status === 'cooldown') {
          inject(cfg);
          showExpired(data.cooldownUntil);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { setTimeout(init, 100); });
  } else {
    setTimeout(init, 150);
  }

  var origPush = history.pushState;
  history.pushState = function() {
    origPush.apply(history, arguments);
    setTimeout(function() { if (isProductPage()) init(); }, 500);
  };
  window.addEventListener('popstate', function() {
    setTimeout(function() { if (isProductPage()) init(); }, 500);
  });

})();
</script>

{% schema %}
{
  "name": "⏱️ Cart Timer (Auto)",
  "target": "head",
  "settings": [
    {
      "type": "paragraph",
      "content": "All settings including discount code are managed from the Cart Timer app dashboard."
    }
  ]
}
{% endschema %}