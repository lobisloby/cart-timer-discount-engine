{% comment %}
  Cart Timer — Real price modification + auto-apply discount to cart
{% endcomment %}

<script>
(function () {
  'use strict';

  var SHOP     = {{ shop.permanent_domain | json }};
   var CURRENCY = {{ cart.currency.iso_code | default: shop.currency | json }};
  var PROXY    = '/apps/timer';

  /* ==========================================================
     VISITOR ID
     ========================================================== */
  function getVid() {
    var k = 'ct_vid', v = localStorage.getItem(k);
    if (v) return v;
    v = 'v_' + Math.random().toString(36).substr(2, 12) + Date.now().toString(36);
    localStorage.setItem(k, v);
    document.cookie = 'ct_vid=' + v + ';path=/;max-age=31536000;SameSite=Lax';
    return v;
  }

  /* ==========================================================
     HELPERS
     ========================================================== */
  function pad(n) { return (n < 10 ? '0' : '') + n; }

  function isProductPage() {
    return !!document.querySelector('form[action*="/cart/add"]')
        || window.location.pathname.indexOf('/products/') > -1;
  }

  function formatMoney(cents) {
    var amount = Math.round(cents) / 100;
    try {
      return new Intl.NumberFormat(navigator.language || 'en-US', {
        style: 'currency',
        currency: CURRENCY
      }).format(amount);
    } catch(e) {
      var symbols = {
        USD:'$', EUR:'€', GBP:'£', CAD:'CA$', AUD:'A$',
        JPY:'¥', INR:'₹', BRL:'R$', MXN:'MX$', CHF:'CHF',
        MAD:'MAD', TRY:'₺', SEK:'kr', NOK:'kr', DKK:'kr'
      };
      return (symbols[CURRENCY] || CURRENCY + ' ') + amount.toFixed(2);
    }
  }

  function api(action, vid) {
    var url = PROXY + '?action=' + action + '&shop=' + encodeURIComponent(SHOP);
    if (vid) url += '&vid=' + encodeURIComponent(vid);
    return fetch(url).then(function(r) { return r.json(); });
  }

  function getProduct() {
    var path = window.location.pathname;
    if (path.indexOf('/products/') === -1) return Promise.resolve(null);
    return fetch(path + '.js').then(function(r) { return r.json(); }).catch(function() { return null; });
  }

  /* ==========================================================
     MODIFY REAL PRODUCT PRICE ON PAGE
     ========================================================== */
  var originalPriceHTML = null;
  var priceContainer = null;

  function findPriceContainer() {
    var selectors = [
      '.price__container',
      '.price',
      '.product__price',
      '.product-price',
      '[data-product-price]',
      '.ProductMeta__Price',
      '.product-single__price',
      '.price-list',
      '.product__info-container .price'
    ];
    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (el) return el;
    }
    return null;
  }

  function modifyPrice(product, discountPct, accentColor) {
    if (!product) return;

    priceContainer = findPriceContainer();
    if (!priceContainer) {
      console.log('[CartTimer] Price container not found');
      return;
    }

    /* Save original */
    originalPriceHTML = priceContainer.innerHTML;

    var priceCents = product.price;
    var discountedCents = Math.round(priceCents * (1 - discountPct / 100));
    var originalFormatted = formatMoney(priceCents);
    var discountedFormatted = formatMoney(discountedCents);

    /* Build new price HTML */
    var html = '<div class="ct-price-mod" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">' +
      '<span style="font-size:inherit;color:#94a3b8;text-decoration:line-through;font-weight:400;">' + originalFormatted + '</span>' +
      '<span style="font-size:1.3em;color:' + accentColor + ';font-weight:800;">' + discountedFormatted + '</span>' +
      '<span style="font-size:0.7em;font-weight:700;color:' + accentColor + ';background:' + accentColor + '15;padding:3px 8px;border-radius:20px;">-' + discountPct + '%</span>' +
    '</div>';

    priceContainer.innerHTML = html;
    console.log('[CartTimer] ✅ Price modified:', originalFormatted, '→', discountedFormatted);
  }

  function restorePrice() {
    if (priceContainer && originalPriceHTML) {
      priceContainer.innerHTML = originalPriceHTML;
      console.log('[CartTimer] Price restored to original');
    }
  }

  /* ==========================================================
     APPLY DISCOUNT CODE TO CART
     ========================================================== */
  var discountApplied = false;

  function applyDiscount(code) {
    if (!code || discountApplied) return;

    /* Use Shopify's /discount/CODE endpoint */
    fetch('/discount/' + encodeURIComponent(code), {
      method: 'GET',
      redirect: 'manual'
    }).then(function() {
      discountApplied = true;
      console.log('[CartTimer] ✅ Discount code applied:', code);
    }).catch(function(err) {
      console.log('[CartTimer] Discount apply attempt:', err.message);
      discountApplied = true; /* May have worked via redirect */
    });
  }

  function interceptAddToCart(code) {
    if (!code) return;

    var forms = document.querySelectorAll('form[action*="/cart/add"]');
    forms.forEach(function(form) {
      if (form.dataset.ctIntercepted) return;
      form.dataset.ctIntercepted = 'true';

      form.addEventListener('submit', function() {
        /* Apply discount after a short delay to let add-to-cart complete */
        setTimeout(function() {
          applyDiscount(code);
        }, 500);
      });

      /* Also intercept AJAX add-to-cart buttons */
      var buttons = form.querySelectorAll('[type="submit"], button[name="add"], .product-form__submit');
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          setTimeout(function() {
            applyDiscount(code);
          }, 800);
        });
      });
    });

    console.log('[CartTimer] 🛒 Intercepting', forms.length, 'add-to-cart forms');
  }

  /* ==========================================================
     CSS
     ========================================================== */
  function injectCSS(accent) {
    if (document.getElementById('ct-css')) return;
    var el = document.createElement('style');
    el.id = 'ct-css';
    el.textContent = '\
.ct-wrap{width:100%;box-sizing:border-box;margin:0 0 16px}\
.ct{--a:' + accent + ';font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;border-radius:14px;padding:18px 20px 16px;position:relative;overflow:hidden;animation:ctIn .4s ease-out;box-sizing:border-box;width:100%}\
.ct *{box-sizing:border-box;margin:0}\
@keyframes ctIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}\
\
.ct-dark{background:linear-gradient(145deg,#0f172a,#1e293b);box-shadow:0 6px 24px rgba(0,0,0,.2)}\
.ct-dark .ct-hl{color:#f1f5f9}.ct-dark .ct-n{color:#fff}.ct-dark .ct-lb{color:rgba(255,255,255,.45)}\
.ct-dark .ct-sp{color:rgba(255,255,255,.25)}.ct-dark .ct-u{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.08)}\
.ct-dark .ct-tk{background:rgba(255,255,255,.1)}.ct-dark .ct-fl{background:var(--a)}\
.ct-dark .ct-ft{color:rgba(255,255,255,.45)}\
.ct-dark .ct-ex{background:rgba(15,23,42,.94)}.ct-dark .ct-em{color:rgba(255,255,255,.6)}\
.ct-dark .ct-cd-msg{color:rgba(255,255,255,.5)}\
\
.ct-gradient{background:linear-gradient(135deg,var(--a),#0f172a);box-shadow:0 6px 24px rgba(0,0,0,.18)}\
.ct-gradient .ct-hl{color:#fff}.ct-gradient .ct-n{color:#fff}.ct-gradient .ct-lb{color:rgba(255,255,255,.55)}\
.ct-gradient .ct-sp{color:rgba(255,255,255,.3)}.ct-gradient .ct-u{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.14)}\
.ct-gradient .ct-tk{background:rgba(255,255,255,.15)}.ct-gradient .ct-fl{background:#fff}\
.ct-gradient .ct-ft{color:rgba(255,255,255,.55)}\
.ct-gradient .ct-ex{background:rgba(15,23,42,.94)}.ct-gradient .ct-em{color:rgba(255,255,255,.7)}\
.ct-gradient .ct-cd-msg{color:rgba(255,255,255,.6)}\
\
.ct-light{background:#fff;border:1px solid #e5e7eb;box-shadow:0 4px 16px rgba(0,0,0,.05)}\
.ct-light .ct-hl{color:#1e293b}.ct-light .ct-n{color:#0f172a}.ct-light .ct-lb{color:#94a3b8}\
.ct-light .ct-sp{color:#cbd5e1}.ct-light .ct-u{background:#f8fafc;border-color:#e2e8f0}\
.ct-light .ct-tk{background:#e2e8f0}.ct-light .ct-fl{background:var(--a)}\
.ct-light .ct-ft{color:#64748b}\
.ct-light .ct-ex{background:rgba(255,255,255,.94)}.ct-light .ct-em{color:#64748b}\
.ct-light .ct-cd-msg{color:#94a3b8}\
\
.ct-hdr{display:flex;align-items:center;gap:8px;margin-bottom:14px}\
.ct-fire{font-size:17px;line-height:1}\
.ct-hl{font-size:14px;font-weight:700;letter-spacing:-.2px}\
\
.ct-cd{display:flex;align-items:flex-start;justify-content:center;gap:6px;margin-bottom:14px}\
.ct-u{display:flex;flex-direction:column;align-items:center;border-radius:10px;padding:10px 14px 7px;min-width:60px;border:1px solid transparent;transition:transform .2s}\
.ct-n{font-size:30px;font-weight:800;line-height:1;font-variant-numeric:tabular-nums;letter-spacing:-.5px}\
.ct-lb{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;margin-top:5px}\
.ct-sp{font-size:24px;font-weight:700;padding-top:8px;line-height:1;animation:ctBlink 1s step-end infinite}\
@keyframes ctBlink{0%,100%{opacity:1}50%{opacity:.2}}\
\
.ct-pg{margin-bottom:12px}.ct-tk{height:4px;border-radius:2px;overflow:hidden}\
.ct-fl{height:100%;border-radius:2px;width:100%;transition:width 1s linear}\
\
.ct-ft{display:flex;align-items:center;justify-content:center;gap:5px;font-size:11px;font-weight:500}\
\
.ct-ex{display:none;position:absolute;inset:0;border-radius:14px;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:2}\
.ct-ex.show{display:flex;flex-direction:column;align-items:center;justify-content:center;animation:ctIn .3s ease-out}\
.ct-eico{font-size:26px;margin-bottom:6px}\
.ct-em{font-size:14px;font-weight:600;margin-bottom:4px}\
.ct-cd-msg{font-size:12px;margin-bottom:12px}\
.ct-rb{background:var(--a);color:#fff;border:none;padding:9px 18px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer}\
.ct-rb:disabled{opacity:.5;cursor:default}\
\
.ct.urgent .ct-u{animation:ctPulse 1s ease-in-out infinite}\
@keyframes ctPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}\
\
@media(max-width:480px){\
.ct{padding:16px 14px 14px;border-radius:12px}\
.ct-cd{gap:4px}.ct-u{min-width:50px;padding:8px 10px 6px}\
.ct-n{font-size:24px}.ct-sp{font-size:20px;padding-top:6px}.ct-lb{font-size:8px}\
.ct-hl{font-size:13px}\
}';
    document.head.appendChild(el);
  }

  /* ==========================================================
     BUILD TIMER HTML (no price inside — price is on the page)
     ========================================================== */
  function buildHTML(cfg) {
    return '<div class="ct-wrap"><div id="ct-timer" class="ct ct-' + cfg.style + '" style="--a:' + cfg.color + ';">' +
      '<div class="ct-hdr"><span class="ct-fire">🔥</span><span class="ct-hl">' + cfg.headline + '</span></div>' +
      '<div class="ct-cd">' +
        '<div class="ct-u"><span class="ct-n" id="ct-h">00</span><span class="ct-lb">Hours</span></div>' +
        '<span class="ct-sp">:</span>' +
        '<div class="ct-u"><span class="ct-n" id="ct-m">' + pad(cfg.minutes) + '</span><span class="ct-lb">Mins</span></div>' +
        '<span class="ct-sp">:</span>' +
        '<div class="ct-u"><span class="ct-n" id="ct-s">00</span><span class="ct-lb">Secs</span></div>' +
      '</div>' +
      '<div class="ct-pg"><div class="ct-tk"><div class="ct-fl" id="ct-f"></div></div></div>' +
      '<div class="ct-ft">' +
        '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' +
        '<span>' + cfg.footer + '</span>' +
      '</div>' +
      '<div id="ct-ex" class="ct-ex">' +
        '<span class="ct-eico">⏰</span>' +
        '<p class="ct-em">Offer expired</p>' +
        '<p class="ct-cd-msg" id="ct-cd-msg"></p>' +
        '<button id="ct-rb" class="ct-rb" disabled>Come back later</button>' +
      '</div>' +
    '</div></div>';
  }

  /* ==========================================================
     TIMER ENGINE
     ========================================================== */
  var interval = null, endTime = 0, totalMs = 0, VID = '';

  function tick() {
    var h = document.getElementById('ct-h'), m = document.getElementById('ct-m'),
        s = document.getElementById('ct-s'), f = document.getElementById('ct-f'),
        t = document.getElementById('ct-timer');
    if (!h) return;

    var left = endTime - Date.now();
    if (left <= 0) {
      clearInterval(interval);
      h.textContent='00'; m.textContent='00'; s.textContent='00'; f.style.width='0%';
      t.classList.remove('urgent');
      onExpire();
      return;
    }

    var sec = Math.floor(left / 1000);
    h.textContent = pad(Math.floor(sec / 3600));
    m.textContent = pad(Math.floor((sec % 3600) / 60));
    s.textContent = pad(sec % 60);
    f.style.width = Math.max(0, (left / totalMs) * 100) + '%';
    if (sec <= 30) t.classList.add('urgent'); else t.classList.remove('urgent');
  }

  function startCountdown(expiresAt, mins) {
    endTime = new Date(expiresAt).getTime();
    totalMs = mins * 60 * 1000;
    tick(); clearInterval(interval); interval = setInterval(tick, 1000);
  }

  /* ==========================================================
     EXPIRE HANDLER
     ========================================================== */
  function onExpire() {
    /* Tell server */
    api('expire', VID).then(function(data) {
      showExpired(data.cooldownUntil);
    }).catch(function() {
      showExpired(null);
    });

    /* Restore original price */
    restorePrice();
  }

  function showExpired(cooldownUntil) {
    var ex = document.getElementById('ct-ex');
    var msg = document.getElementById('ct-cd-msg');
    var btn = document.getElementById('ct-rb');
    if (!ex) return;
    ex.classList.add('show');

    if (cooldownUntil) {
      var cdEnd = new Date(cooldownUntil).getTime();
      btn.disabled = true; btn.textContent = 'Come back later';
      function upd() {
        var left = cdEnd - Date.now();
        if (left <= 0) { msg.textContent='New offer ready!'; btn.disabled=false; btn.textContent='🎉 Get new discount'; return; }
        var hrs = Math.floor(left/3600000), mins = Math.floor((left%3600000)/60000);
        msg.textContent = 'New discount in ' + hrs + 'h ' + mins + 'm';
      }
      upd(); setInterval(upd, 60000);
    }

    btn.onclick = function() {
      if (btn.disabled) return;
      ex.classList.remove('show');
      startNewTimer();
    };
  }

  function startNewTimer() {
    api('start', VID).then(function(data) {
      if (data.status === 'active') {
        startCountdown(data.expiresAt, data.timerMinutes);
        if (data.discountCode) {
          applyDiscount(data.discountCode);
          discountApplied = false;
        }
        /* Re-modify price */
        getProduct().then(function(p) {
          if (p) modifyPrice(p, data.discountPct, document.getElementById('ct-timer')?.style.getPropertyValue('--a') || '#6366f1');
        });
      } else if (data.status === 'cooldown') {
        showExpired(data.cooldownUntil);
      }
    });
  }

  /* ==========================================================
     INJECT
     ========================================================== */
  function findTarget() {
    var sels = ['.product-form__buttons','.product-form__submit','.product__submit',
      '.shopify-payment-button','form[action*="/cart/add"] [type="submit"]',
      'button[name="add"]','[data-add-to-cart]','#AddToCart','.add-to-cart',
      'form[action*="/cart/add"]'];
    for (var i=0;i<sels.length;i++) { var el=document.querySelector(sels[i]); if(el) return el; }
    return null;
  }

  function inject(cfg) {
    if (document.getElementById('ct-timer')) return;
    var target = findTarget();
    if (!target) return;

    var form = target.closest('form[action*="/cart/add"]');
    var parent = form || target.parentElement;

    injectCSS(cfg.color);
    var wrap = document.createElement('div');
    wrap.innerHTML = buildHTML(cfg);
    var node = wrap.firstElementChild;

    var btnGroup = parent.querySelector('.product-form__buttons')
                || parent.querySelector('.shopify-payment-button')
                || parent.querySelector('[type="submit"]');
    if (btnGroup && btnGroup.parentElement === parent) {
      parent.insertBefore(node, btnGroup);
    } else {
      parent.insertBefore(node, parent.firstChild);
    }
  }

  /* ==========================================================
     MAIN INIT
     ========================================================== */
  function init() {
    if (!isProductPage()) return;

    VID = getVid();

    Promise.all([api('settings', null), getProduct()])
    .then(function(results) {
      var settings = results[0];
      var product = results[1];

      if (!settings || settings.enabled === false) return;

      var cfg = {
        style:    settings.timerStyle      || 'dark',
        minutes:  settings.timerMinutes    || 10,
        discount: settings.discountPercent || 15,
        headline: settings.urgencyText     || 'Hurry! This deal ends soon',
        color:    settings.primaryColor     || '#6366f1',
        footer:   settings.footerText       || 'Your discount is reserved for you',
        code:     settings.discountCode     || null
      };

      /* 1. Inject timer widget */
      inject(cfg);

      /* 2. Start/resume timer via server */
      api('start', VID).then(function(data) {
        if (data.status === 'active') {
          var pct = data.discountPct || cfg.discount;

          /* 3. Modify REAL price on the page */
          if (product) modifyPrice(product, pct, cfg.color);

          /* 4. Intercept add-to-cart to apply discount code */
          var code = data.discountCode || cfg.code;
          if (code) {
            interceptAddToCart(code);
            /* Pre-apply discount so it's ready when they add to cart */
            applyDiscount(code);
          }

          /* 5. Start countdown */
          startCountdown(data.expiresAt, data.timerMinutes || cfg.minutes);

        } else if (data.status === 'cooldown') {
          inject(cfg); /* Inject timer in expired state */
          showExpired(data.cooldownUntil);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { setTimeout(init, 100); });
  } else {
    setTimeout(init, 150);
  }

  /* SPA */
  var origPush = history.pushState;
  history.pushState = function() {
    origPush.apply(history, arguments);
    setTimeout(function() { if (isProductPage()) init(); }, 500);
  };
  window.addEventListener('popstate', function() {
    setTimeout(function() { if (isProductPage()) init(); }, 500);
  });

})();
</script>

{% schema %}
{
  "name": "⏱️ Cart Timer (Auto)",
  "target": "head",
  "settings": [
    {
      "type": "paragraph",
      "content": "All settings including discount code are managed from the Cart Timer app dashboard."
    }
  ]
}
{% endschema %}