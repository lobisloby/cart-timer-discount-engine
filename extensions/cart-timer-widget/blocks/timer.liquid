{% comment %}
  Cart Timer Discount Widget
{% endcomment %}

<div 
  id="cart-timer-widget"
  class="cart-timer-widget"
  data-shop="{{ shop.permanent_domain }}"
>
  <!-- Timer Container -->
  <div id="timer-container" class="timer-container">
    <div class="timer-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
    </div>

    <div class="timer-content">
      <p class="timer-message">
        🎁 Complete your order for <strong id="discount-amount">10%</strong> off!
      </p>
      
      <!-- Progress Bar -->
      <div id="progress-container" class="progress-container">
        <div class="progress-bar">
          <div id="progress-fill" class="progress-fill"></div>
        </div>
        <span id="progress-time" class="progress-time">10:00</span>
      </div>

      <!-- Countdown -->
      <div id="countdown-container" class="countdown-container" style="display: none;">
        <span id="countdown-time" class="countdown-time">10:00</span>
        <span class="countdown-label">remaining</span>
      </div>
    </div>

    <button id="timer-close" class="timer-close" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Expired State -->
  <div id="timer-expired" class="timer-expired" style="display: none;">
    <span>⏰ Discount expired.</span>
    <button id="restart-timer" class="restart-btn">Get new discount</button>
  </div>
</div>

<style>
  .cart-timer-widget {
    --timer-color: #6366f1;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: linear-gradient(135deg, #fff 0%, #f8fafc 100%);
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px 20px;
    margin: 16px 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .timer-container {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .timer-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: var(--timer-color);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .timer-content {
    flex: 1;
    min-width: 0;
  }

  .timer-message {
    margin: 0 0 10px 0;
    font-size: 15px;
    color: #1e293b;
    font-weight: 500;
  }

  .timer-message strong {
    color: var(--timer-color);
    font-weight: 700;
  }

  .progress-container {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .progress-bar {
    flex: 1;
    height: 8px;
    background: #e2e8f0;
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--timer-color);
    border-radius: 4px;
    transition: width 1s linear;
    width: 100%;
  }

  .progress-time {
    font-size: 13px;
    color: #64748b;
    font-weight: 600;
    min-width: 45px;
  }

  .countdown-container {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .countdown-time {
    font-size: 28px;
    font-weight: 700;
    color: var(--timer-color);
  }

  .countdown-label {
    font-size: 14px;
    color: #64748b;
  }

  .timer-close {
    width: 32px;
    height: 32px;
    border: none;
    background: #f1f5f9;
    color: #94a3b8;
    cursor: pointer;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .timer-close:hover {
    background: #e2e8f0;
    color: #64748b;
  }

  .timer-expired {
    text-align: center;
    padding: 8px 0;
    color: #64748b;
    font-size: 14px;
  }

  .restart-btn {
    background: var(--timer-color);
    border: none;
    color: white;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    margin-left: 10px;
  }

  @media (max-width: 480px) {
    .cart-timer-widget {
      padding: 12px 16px;
    }
    .timer-icon {
      width: 36px;
      height: 36px;
    }
    .timer-message {
      font-size: 14px;
    }
  }
</style>

<script>
(function() {
  const widget = document.getElementById('cart-timer-widget');
  if (!widget) return;

  const shop = widget.dataset.shop;
  
  // Default settings
  let config = {
    discountPercent: 10,
    timerMinutes: 10,
    displayStyle: 'progress',
    primaryColor: '#6366f1'
  };

  // Elements
  const container = document.getElementById('timer-container');
  const expired = document.getElementById('timer-expired');
  const discount = document.getElementById('discount-amount');
  const progressBox = document.getElementById('progress-container');
  const countdownBox = document.getElementById('countdown-container');
  const progressFill = document.getElementById('progress-fill');
  const progressTime = document.getElementById('progress-time');
  const countdownTime = document.getElementById('countdown-time');
  const closeBtn = document.getElementById('timer-close');
  const restartBtn = document.getElementById('restart-timer');

  let interval = null;
  let endTime = null;
  let totalMs = 0;

  function formatTime(ms) {
    if (ms <= 0) return '00:00';
    const s = Math.floor(ms / 1000);
    return String(Math.floor(s / 60)).padStart(2, '0') + ':' + String(s % 60).padStart(2, '0');
  }

  function setColor(c) {
    widget.style.setProperty('--timer-color', c);
  }

  function showExpired() {
    clearInterval(interval);
    container.style.display = 'none';
    expired.style.display = 'block';
    localStorage.removeItem('cart_timer_' + shop);
  }

  function update() {
    const remain = endTime - Date.now();
    if (remain <= 0) {
      showExpired();
      return;
    }
    const pct = (remain / totalMs) * 100;
    if (config.displayStyle === 'countdown') {
      countdownTime.textContent = formatTime(remain);
    } else {
      progressFill.style.width = pct + '%';
      progressTime.textContent = formatTime(remain);
    }
  }

  function start(exp) {
    endTime = new Date(exp).getTime();
    totalMs = config.timerMinutes * 60 * 1000;
    
    discount.textContent = config.discountPercent + '%';
    setColor(config.primaryColor);
    
    if (config.displayStyle === 'countdown') {
      countdownBox.style.display = 'flex';
      progressBox.style.display = 'none';
    } else {
      progressBox.style.display = 'flex';
      countdownBox.style.display = 'none';
    }
    
    container.style.display = 'flex';
    expired.style.display = 'none';
    
    update();
    interval = setInterval(update, 1000);
  }

  function newTimer() {
    const exp = new Date(Date.now() + config.timerMinutes * 60 * 1000).toISOString();
    localStorage.setItem('cart_timer_' + shop, exp);
    start(exp);
  }

  // Event listeners
  closeBtn.addEventListener('click', function() {
    widget.style.display = 'none';
    sessionStorage.setItem('cart_timer_hidden', 'true');
  });

  restartBtn.addEventListener('click', newTimer);

  // Initialize
  if (sessionStorage.getItem('cart_timer_hidden') === 'true') {
    widget.style.display = 'none';
    return;
  }

  const saved = localStorage.getItem('cart_timer_' + shop);
  if (saved && new Date(saved) > new Date()) {
    start(saved);
  } else if (saved) {
    showExpired();
  } else {
    newTimer();
  }
})();
</script>

{% schema %}
{
  "name": "Cart Timer Discount",
  "target": "section",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Timer settings are configured in the Cart Timer app."
    }
  ]
}
{% endschema %}