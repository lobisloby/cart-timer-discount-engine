{% comment %}
  Cart Timer — Section Block (manual placement)
  Uses same proxy API as embed
{% endcomment %}

<div id="ct-block-root" data-shop="{{ shop.permanent_domain }}" data-currency="{{ shop.currency }}"></div>

<script>
(function(){
  var root = document.getElementById('ct-block-root');
  if (!root) return;
  var SHOP = root.dataset.shop;
  var CURRENCY = root.dataset.currency;

  fetch('/apps/timer?action=settings&shop=' + encodeURIComponent(SHOP))
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (!data || data.enabled === false) { root.style.display='none'; return; }
      root.innerHTML = '<p style="text-align:center;padding:20px;color:#64748b;font-family:system-ui;font-size:13px;">✅ Timer active — use the App Embed version for automatic placement near Add to Cart button.</p>';
    })
    .catch(function(){
      root.style.display = 'none';
    });
})();
</script>

{% schema %}
{
  "name": "⏱️ Countdown Timer",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "For best results, use the App Embed version (⏱️ Cart Timer Auto) which automatically positions near the Add to Cart button."
    }
  ]
}
{% endschema %}