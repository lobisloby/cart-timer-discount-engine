generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify Session (required - don't modify fields)
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@map("ct_sessions")
}

// Campaign Settings - one per shop
model Campaign {
  id                 String   @id @default(cuid())
  shop               String   @unique

  // Core Settings
  enabled            Boolean  @default(false)
  discountPercent    Int      @default(10)
  timerMinutes       Int      @default(10)

  // Display Settings
  displayStyle       String   @default("progress")
  primaryColor       String   @default("#6366f1")
  timerStyle         String   @default("dark")
  urgencyText        String   @default("Hurry! This deal ends soon")
  footerText         String   @default("Your discount is reserved for you")

  // Shopify Discount
  discountCode       String?
  shopifyDiscountId  String?

  // Timestamps
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("ct_campaigns")
}

// Active Timer Sessions - tracks each customer's timer
model TimerSession {
  id            String    @id @default(cuid())
  shop          String
  visitorId     String
  expiresAt     DateTime
  discountPct   Int       @default(10)
  timerMinutes  Int       @default(10)
  isExpired     Boolean   @default(false)
  cooldownUntil DateTime?
  createdAt     DateTime  @default(now())

  @@unique([shop, visitorId])
  @@index([shop])
  @@index([expiresAt])
  @@map("ct_timer_sessions")
}

model Shop {
  id          String   @id @default(uuid())
  shop        String   @unique
  installedAt DateTime @default(now())
  plan        String   @default("trial")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ct_shops")
}