// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

// Shopify Session (required - don't modify)
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Campaign Settings - one per shop
model Campaign {
  id              String   @id @default(cuid())
  shop            String   @unique

  // Core Settings
  enabled         Boolean  @default(false)
  discountPercent Int      @default(10)
  timerMinutes    Int      @default(10)

  // Display Settings
  displayStyle    String   @default("progress")
  primaryColor    String   @default("#6366f1")

  // NEW: Timer Design
  timerStyle      String   @default("dark")
  urgencyText     String   @default("Hurry! This deal ends soon")
  footerText      String   @default("Your discount is reserved for you")

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Active Timer Sessions - tracks each customer's timer
model TimerSession {
  id           String   @id @default(cuid())
  shop         String
  cartToken    String   
  expiresAt    DateTime
  discountCode String?
  isExpired    Boolean  @default(false)
  createdAt    DateTime @default(now())
  
  @@unique([shop, cartToken])
  @@index([shop])
  @@index([expiresAt])
}